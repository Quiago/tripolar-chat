# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/factorymind.db
# For production:
# DATABASE_URL=postgresql://user:pass@db-host/factorymind

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-random-32-char-string

API_KEY_HEADER=X-API-Key

# ── vLLM ──────────────────────────────────────────────────────────────────────
VLLM_PORT=8000
HF_HOME=/cache/huggingface
TRANSFORMERS_CACHE=/cache/huggingface
CUDA_VISIBLE_DEVICES=0

# ── Features ──────────────────────────────────────────────────────────────────
ENABLE_REGISTRATION=true
MAX_CHAT_HISTORY=100

# ── Cold-start warm-up ────────────────────────────────────────────────────────
# Model loaded into GPU at server startup (eliminates first-request delay).
# Must match a key in MODEL_CATALOG (see server/services/vllm_manager.py).
DEFAULT_MODEL=llama-3.1-8b-awq

# Download weights for ALL catalog models to disk at startup (no GPU use).
# Set to false to skip pre-fetching and only load the default model.
PREFETCH_ALL_MODELS=true
